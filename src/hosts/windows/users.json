{
  "description": "Windows host user registry — defines users managed by this host configuration. Each user has a home directory, role (primary vs secondary), and optional devRepos config. The primary user receives secret materialization; secondary users get base configuration only. This mirrors the Nix users/default.nix structure.",
  "users": {
    "polyipseity": {
      "description": "Primary user receiving secret materialization and full configuration",
      "cloudDrives": {
        "mounts": [
          {
            "enable": true,
            "extraArgs": [],
            "id": "GoogleDrive",
            "localPath": "clouds\\GoogleDrive",
            "provider": "GoogleDrive",
            "readWrite": true,
            "remoteName": "GoogleDrive",
            "remotePath": "/"
          },
          {
            "enable": false,
            "extraArgs": [],
            "id": "iCloud",
            "localPath": "clouds\\iCloud",
            "provider": "iCloud",
            "readWrite": false,
            "remoteName": null,
            "remotePath": "/",
            "_why_disabled": "iCloud Drive does not have a supported rclone backend on Windows; use native OneDrive/Google Drive instead."
          },
          {
            "enable": true,
            "extraArgs": [],
            "id": "OneDrive",
            "localPath": "clouds\\OneDrive",
            "provider": "OneDrive",
            "readWrite": true,
            "remoteName": "OneDrive",
            "remotePath": "/"
          }
        ],
        "replicas": [
          {
            "direction": "bidirectional",
            "enable": false,
            "fallbackTimer": {
              "enable": true,
              "interval": "daily"
            },
            "id": "GoogleDrive",
            "localPath": "clouds\\GoogleDriveReplica",
            "provider": "GoogleDrive",
            "realtime": {
              "debounceSeconds": 5,
              "enable": true
            },
            "remoteName": "GoogleDrive",
            "remotePath": "/"
          },
          {
            "direction": "bidirectional",
            "enable": false,
            "fallbackTimer": {
              "enable": true,
              "interval": "daily"
            },
            "id": "iCloud",
            "localPath": "clouds\\iCloudReplica",
            "provider": "iCloud",
            "realtime": {
              "debounceSeconds": 5,
              "enable": true
            },
            "remoteName": null,
            "remotePath": "/",
            "_why_disabled": "iCloud Drive is not accessible via rclone on Windows."
          },
          {
            "direction": "bidirectional",
            "enable": false,
            "fallbackTimer": {
              "enable": true,
              "interval": "daily"
            },
            "id": "OneDrive",
            "localPath": "clouds\\OneDriveReplica",
            "provider": "OneDrive",
            "realtime": {
              "debounceSeconds": 5,
              "enable": true
            },
            "remoteName": "OneDrive",
            "remotePath": "/"
          }
        ]
      },
      "devRepos": {
        "enable": true,
        "gitHubUsername": "polyipseity",
        "repositories": [
          {
            "name": "nucleus",
            "symlinkFromRepoRoot": true,
            "target": "dev\\nucleus"
          },
          {
            "name": "monorepo",
            "target": "dev\\monorepo",
            "url": "git@github.com:polyipseity/monorepo.git"
          },
          {
            "name": "monorepo-private",
            "target": "dev\\monorepo-private",
            "url": "git@github.com:polyipseity/monorepo-private.git"
          }
        ]
      },
      "dscConfigFiles": [
        "user.dsc.yml"
      ],
      "homeDirectory": "C:\\Users\\polyipseity",
      "isPrimary": true,
      "linearmouse": {
        "settings": {}
      },
      "obsidian": {
        "settings": {}
      },
      "qtpass": {
        "settings": {}
      },
      "neovim": {
        "settings": {}
      },
      "vscode": {
        "settings": {}
      }
    }
  }
}
