{
  "polyipseity": {
    "homeDirectory": "/Users/polyipseity",
    "isPrimary": true,
    "passwordStore": {
      "path": "~/dev/monorepo-private/self/passwords"
    },
    "qtpass": {
      "settings": {}
    },
    "linearmouse": {
      "settings": {}
    },
    "vsCode": {
      "settings": {}
    },
    "neovim": {
      "settings": {}
    },
    "obsidian": {
      "settings": {}
    },
    "cloudDrives": {
      "mounts": [
        {
          "displayName": "Google Drive",
          "enable": true,
          "extraArgs": [],
          "id": "GoogleDrive",
          "localPath": "clouds/GoogleDrive",
          "provider": "GoogleDrive",
          "readWrite": true,
          "remoteName": "GoogleDrive",
          "remotePath": "/"
        },
        {
          "enable": true,
          "extraArgs": [],
          "id": "iCloud",
          "iCloudService": "drive",
          "localPath": "clouds/iCloud",
          "provider": "iCloud",
          "readWrite": false,
          "remoteName": "iCloud",
          "remotePath": "/"
        },
        {
          "enable": true,
          "extraArgs": [],
          "id": "OneDrive",
          "localPath": "clouds/OneDrive",
          "provider": "OneDrive",
          "readWrite": true,
          "remoteName": "OneDrive",
          "remotePath": "/"
        }
      ],
      "replicas": [
        {
          "direction": "pull",
          "enable": false,
          "fallbackTimer": {
            "enable": true,
            "interval": "daily"
          },
          "id": "GoogleDrive",
          "localPath": "clouds/GoogleDriveReplica",
          "provider": "GoogleDrive",
          "realtime": {
            "debounceSeconds": 5,
            "enable": true
          },
          "remoteName": "GoogleDrive",
          "remotePath": "/"
        },
        {
          "direction": "pull",
          "enable": true,
          "fallbackTimer": {
            "enable": true,
            "interval": "daily"
          },
          "id": "iCloud",
          "iCloudService": "drive",
          "localPath": "clouds/iCloudReplica",
          "provider": "iCloud",
          "realtime": {
            "debounceSeconds": 5,
            "enable": true
          },
          "remoteName": "iCloud",
          "remotePath": "/"
        },
        {
          "direction": "pull",
          "enable": true,
          "fallbackTimer": {
            "enable": true,
            "interval": "daily"
          },
          "id": "OneDrive",
          "localPath": "clouds/OneDriveReplica",
          "provider": "OneDrive",
          "realtime": {
            "debounceSeconds": 5,
            "enable": true
          },
          "remoteName": "OneDrive",
          "remotePath": "/"
        }
      ]
    },
    "iCloudExclusions": {
      "managedRoots": [
        "Library/Mobile Documents",
        "Downloads/iCloud",
        "clouds/iCloud"
      ],
      "excludedDirNames": [
        ".direnv",
        ".hypothesis",
        ".mypy_cache",
        ".next",
        ".nox",
        ".npm",
        ".parcel-cache",
        ".pnpm-store",
        ".pytest_cache",
        ".ruff_cache",
        ".tox",
        ".turbo",
        ".venv",
        ".yarn",
        "__pycache__",
        "build",
        "dist",
        "node_modules",
        "target",
        "venv"
      ]
    },
    "devRepos": {
      "enable": true,
      "gitHubUsername": "polyipseity",
      "repositories": [
        {
          "name": "nucleus",
          "symlinkFromRepoRoot": true,
          "target": "dev/nucleus"
        },
        {
          "name": "monorepo",
          "url": "git@github.com:polyipseity/monorepo.git",
          "target": "dev/monorepo"
        },
        {
          "name": "monorepo-private",
          "url": "git@github.com:polyipseity/monorepo-private.git",
          "target": "dev/monorepo-private"
        }
      ],
      "submoduleDirectories": [
        {
          "path": "dev/monorepo",
          "recursive": false
        },
        {
          "path": "dev/monorepo-private",
          "recursive": false
        },
        {
          "path": "dev/monorepo/self/obsidian-monorepo",
          "recursive": true
        },
        {
          "path": "dev/monorepo-private/orgs/*",
          "recursive": false
        }
      ]
    }
  }
}
