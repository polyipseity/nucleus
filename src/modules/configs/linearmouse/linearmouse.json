{
  "schemes": [
    {
      "if": {
        "device": {
          "category": "mouse"
        }
      },
      "pointer": {
        "acceleration": 0
      },
      "scrolling": {
        "reverse": {
          "horizontal": false,
          "vertical": false
        }
      }
    },
    {
      "if": {
        "device": {
          "category": "trackpad"
        }
      },
      "scrolling": {
        "reverse": {
          "horizontal": true,
          "vertical": true
        }
      }
    },
    {
      "if": [
        {
          "app": "org.gimp.gimp",
          "device": {
            "category": "mouse"
          }
        },
        {
          "processName": "gimp",
          "device": {
            "category": "mouse"
          }
        },
        {
          "processPath": "/Applications/GIMP.app/Contents/MacOS/gimp",
          "device": {
            "category": "mouse"
          }
        },
        {
          "processPath": "/Applications/GIMP.app/Contents/MacOS/gimp-3",
          "device": {
            "category": "mouse"
          }
        },
        {
          "processPath": "/Applications/GIMP.app/Contents/MacOS/gimp-3.2",
          "device": {
            "category": "mouse"
          }
        }
      ],
      "scrolling": {
        "speed": {
          "horizontal": 0.25,
          "vertical": 0.25
        }
      }
    }
  ]
}
